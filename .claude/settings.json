{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$HOME/Desktop/dme/projects/.lobby/scripts/memory-sync-hook.sh\"",
            "timeout": 10
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "rtk hook claude"
          },
          {
            "type": "command",
            "command": "python3 \"$HOME/.claude/hooks/cct-dangerous-command-blocker.py\""
          },
          {
            "type": "command",
            "command": "python3 \"$HOME/.claude/hooks/cct-secret-scanner.py\""
          },
          {
            "type": "command",
            "command": "bash \"$HOME/.claude/hooks/block-env-commit.sh\"",
            "if": "Bash(git add *)",
            "statusMessage": "Verificando .env..."
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'FILE=$(echo \"$TOOL_INPUT\" | jq -r \".file_path // empty\"); if [ -n \"$FILE\" ]; then EXT=\"${FILE##*.}\"; case \"$EXT\" in ts|tsx|js|jsx) if [ -f \"$(dirname \"$FILE\")/node_modules/.bin/eslint\" ] || command -v npx &>/dev/null; then npx --no-install eslint --fix \"$FILE\" 2>/dev/null || true; fi;; py) if command -v ruff &>/dev/null; then ruff check --fix \"$FILE\" 2>/dev/null && ruff format \"$FILE\" 2>/dev/null || true; fi;; esac; fi'",
            "timeout": 15,
            "statusMessage": "Auto-lint..."
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash ~/.claude/statusline-command.sh"
  },
  "enabledPlugins": {
    "context7@claude-plugins-official": true,
    "commit-commands@claude-plugins-official": true,
    "claude-md-management@claude-plugins-official": true,
    "pyright-lsp@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": true,
    "skill-creator@claude-plugins-official": true,
    "playwright@claude-plugins-official": true
  },
  "language": "Português",
  "effortLevel": "low",
  "skipDangerousModePermissionPrompt": true,
  "voiceEnabled": true
}
