{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "model": "opus[1m]",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"$HOME/.claude/hooks/gsd-check-update.js\""
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"$HOME/.claude/hooks/gsd-context-monitor.js\""
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$HOME/.claude/hooks/cct-dangerous-command-blocker.py\""
          },
          {
            "type": "command",
            "command": "python3 \"$HOME/.claude/hooks/cct-prevent-direct-push.py\""
          },
          {
            "type": "command",
            "command": "python3 \"$HOME/.claude/hooks/cct-conventional-commits.py\""
          },
          {
            "type": "command",
            "command": "python3 \"$HOME/.claude/hooks/cct-secret-scanner.py\""
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "node \"$HOME/.claude/hooks/gsd-statusline.js\""
  },
  "enabledPlugins": {
    "claude-mem@thedotmack": false,
    "code-review@claude-plugins-official": true,
    "security-guidance@claude-plugins-official": true,
    "frontend-design@claude-plugins-official": true,
    "plugin-dev@claude-plugins-official": false,
    "pr-review-toolkit@claude-plugins-official": false,
    "claude-code-setup@claude-plugins-official": false,
    "feature-dev@claude-plugins-official": true,
    "github@claude-plugins-official": false,
    "context7@claude-plugins-official": true,
    "playwright@claude-plugins-official": true,
    "linear@claude-plugins-official": false,
