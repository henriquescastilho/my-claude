{
  "mcpServers": {
    "n8n-mcp": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "n8n-mcp"
      ],
      "env": {
        "MCP_MODE": "stdio",
        "LOG_LEVEL": "error",
        "DISABLE_CONSOLE_OUTPUT": "true"
      }
    },
    "claude-skills-mcp": {
      "type": "stdio",
      "command": "uvx",
      "args": [
        "claude-skills-mcp"
      ],
      "env": {}
    },
    "mem-hybrid": {
      "type": "stdio",
      "command": "$HOME/.claude-mem-hybrid/run_mem_hybrid.sh",
      "args": [],
      "env": {}
    },
    "magic": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@21st-dev/magic@latest"
      ],
      "env": {
        "API_KEY": "${API_KEY}"
      }
    }
  }
}